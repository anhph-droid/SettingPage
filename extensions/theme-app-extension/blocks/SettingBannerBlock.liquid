{% liquid
  assign settings_banner_block_root_id = 'settings-banner-block-' | append: block.id
%}

<div
  id="{{ settings_banner_block_root_id }}"
  data-settings-banner-slot="true"
  data-render-mode="section"
  data-banner-id="{{ block.settings.banner_id | escape }}"
  {{ block.shopify_attributes }}
></div>

{% render 'settings-banner-styles',
  root_id: settings_banner_block_root_id
%}

{% render 'settings-banner-script',
  root_id: settings_banner_block_root_id,
  current_product_id: product.id
%}

{% schema %}
{
  "name": "Settings Banner",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "banner_id",
      "label": "Banner ID",
      "placeholder": "VD: 123",
      "info": "Nhập Banner ID để hiển thị banner small, large hoặc inline trong section/theme."
    }
  ]
}
{% endschema %}
