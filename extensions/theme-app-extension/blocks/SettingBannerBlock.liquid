{% liquid
  assign settings_banner_block_root_id = 'settings-banner-block-' | append: block.id
%}

{% render 'settings-banner-content',
  root_id: settings_banner_block_root_id,
  include_block_attributes: true,
  banner_id: block.settings.banner_id,
  render_mode: 'section',
  force_size: block.settings.banner_size
%}

{% schema %}
{
  "name": "Settings Banner",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "banner_size",
      "label": "Kiểu banner",
      "default": "bar",
      "options": [
        { "value": "bar", "label": "Bar" },
        { "value": "inline", "label": "Inline" },
        { "value": "large", "label": "Large" },
        { "value": "small", "label": "Small" }
      ],
      "info": "Chọn kiểu hiển thị của banner khi sử dụng ID này."
    },
    {
      "type": "text",
      "id": "banner_id",
      "label": "Banner ID",
      "placeholder": "VD: 123",
      "info": "Nhập ID banner (số) từ bảng quản trị banner của app để hiển thị banner đó trên theme."
    }
  ]
}
{% endschema %}
