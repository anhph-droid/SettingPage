{% liquid
  assign settings_banner_block_root_id = 'settings-banner-bar-block-' | append: block.id
%}

{% render 'settings-banner-content',
  root_id: settings_banner_block_root_id,
  include_block_attributes: true,
  banner_id: block.settings.banner_id,
  render_mode: 'section',
  force_size: 'bar'
%}

{% schema %}
{
  "name": "Bar Banner",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "banner_id",
      "label": "Banner ID",
      "info": "Nhập ID banner muốn hiển thị theo kiểu Bar."
    }
  ]
}
{% endschema %}
