
{% liquid
  assign settings_banner_embed_root_id = 'settings-banner-embed-' | append: block.id
%}

{% render 'settings-banner-content',
  root_id: settings_banner_embed_root_id,
  include_block_attributes: false,
  banner_id: block.settings.banner_id,
  render_mode: 'embed',
  force_size: 'bar'
%}

{% schema %}
{
  "name": "Settings Banner Embed",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "banner_id",
      "label": "Banner ID",
      "info": "Nhập ID banner muốn hiển thị trên storefront."
    }
  ]
}
{% endschema %}
