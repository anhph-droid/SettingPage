{% assign title      = shop.metafields.banner.title.value %}
{% assign content    = shop.metafields.banner.content.value %}
{% assign link       = shop.metafields.banner.link.value %}
{% assign bg         = shop.metafields.banner.background_color.value %}
{% assign color      = shop.metafields.banner.color.value %}
{% assign time_end   = shop.metafields.banner.time_end.value %}
{% assign status     = shop.metafields.banner.status.value %}


<!-- ===== CSS ===== -->

<style>
.banner-scroll {
  white-space: nowrap;
  overflow: hidden;
}

.banner-scroll span {
  display: inline-block;
  padding-left: 100%;
  animation: scrollLeft 18s linear infinite;
  font-weight: 600;
}

/* chạy ngược */
.banner-scroll.reverse span {
  animation: scrollRight 18s linear infinite;
}

.banner-scroll span:hover {
  animation-play-state: paused;
}

@keyframes scrollLeft {
  from { transform: translateX(0); }
  to { transform: translateX(-100%); }
}

@keyframes scrollRight {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}
</style>

<!-- ===== banner run ===== -->

{% if status == true or status == "true" %}
<div id="settings-banner" style="background:white ; color: {{ color }}; width: 100%; overflow: hidden;">

  <div class="banner-scroll">
    <span>
      {{ title }} — {{ content }}
      &nbsp;&nbsp;&nbsp;&nbsp;
      {{ title }} — {{ content }}
    </span>
  </div>

<!-- ===== body ===== -->

<div id="settings-banner" style="background: {{ bg }}; color: {{ color }}; width: 100%; overflow: hidden;">
  <div style="padding: 20px; text-align: center;">

    <h2 style="margin: 0 0 10px 0;">
      {% if link != blank %}
        <a href="{{ link }}" style="color: inherit; text-decoration: none;">
          {{ title }}
        </a>
      {% else %}
        {{ title }}
      {% endif %}
    </h2>

    <p>{{ content }}</p>

    {% if time_end != blank %}
      <div id="countdown">
        <span id="days">00</span>d
        <span id="hours">00</span>h
        <span id="minutes">00</span>m
        <span id="seconds">00</span>s
      </div>
    {% endif %}
  </div>

<!-- ===== banner run ===== -->

  <div style="background: white; color: {{ color }}; overflow: hidden;">
  <div class="banner-scroll reverse">
    <span>
       {{ content }} — {{ title }} 
      &nbsp;&nbsp;&nbsp;&nbsp;
       {{ content }} — {{ title }} 
    </span>
  </div>
</div>

<!-- ===== COUNTDOWN ===== --> 

{% if time_end != blank %}
<script>
(function() {
  const endStr = "{{ time_end | date: '%Y-%m-%dT%H:%M:%S' }}";
  if (!endStr) return;

  const endTime = new Date(endStr).getTime();

  function updateCountdown() {
    const distance = endTime - Date.now();

    if (distance <= 0) {
      const el = document.getElementById('countdown');
      if (el) el.innerHTML = 'Ended';
      return;
    }

    const days    = Math.floor(distance / 86400000);
    const hours   = Math.floor((distance % 86400000) / 3600000);
    const minutes = Math.floor((distance % 3600000) / 60000);
    const seconds = Math.floor((distance % 60000) / 1000);

    document.getElementById('days').textContent = String(days).padStart(2,'0');
    document.getElementById('hours').textContent = String(hours).padStart(2,'0');
    document.getElementById('minutes').textContent = String(minutes).padStart(2,'0');
    document.getElementById('seconds').textContent = String(seconds).padStart(2,'0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
})();

</script>
{% endif %}
{% endif %}

{% schema %}
{
  "name": "Settings Banner",
  "target": "section"
}
{% endschema %}