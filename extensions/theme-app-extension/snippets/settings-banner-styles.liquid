<style>
  body.settings-banner-visible {
    padding-top: var(--settings-banner-offset, 0px) !important;
    transition: padding-top 0.2s ease;
  }

  #{{ root_id }} {
    --settings-banner-panel: #1f2027;
    --settings-banner-panel-soft: #2a2c35;
    --settings-banner-text: #f8fafc;
    --settings-banner-muted: rgba(248, 250, 252, 0.72);
    --settings-banner-shadow: 0 16px 36px rgba(17, 24, 39, 0.18);
  }

  #{{ root_id }}[data-render-mode="embed"] {
    position: fixed;
    inset: 0;
    z-index: 999999;
    pointer-events: none;
  }

  #{{ root_id }}[data-render-mode="section"] {
    position: relative;
    width: 100%;
    max-width: 100%;
    overflow: visible;
    pointer-events: auto;
  }

  .settings-banner-stack {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner-stack {
    position: fixed;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner-stack {
    position: relative;
    width: 100%;
    overflow: visible;
    pointer-events: auto;
  }

  .settings-banner-stack--top {
    top: 0;
  }

  .settings-banner-stack--bottom {
    bottom: 0;
  }

  .settings-banner {
    width: 100%;
    position: relative;
    pointer-events: auto;
    background: var(--settings-banner-panel);
    border: 1px solid rgba(91, 142, 247, 0.28);
    box-shadow: var(--settings-banner-shadow);
    overflow: hidden;
  }

  .settings-banner--small,
  .settings-banner--inline {
    width: auto;
    max-width: min(92vw, 560px);
    margin: 12px auto 0;
    border-radius: 20px;
  }

  .settings-banner--small {
    max-width: min(92vw, 400px);
  }

  .settings-banner--inline {
    width: auto;
    min-height: 160px;
    border-radius: 18px;
    box-shadow: 0 12px 30px rgba(17, 24, 39, 0.14);
  }

  .settings-banner--large {
    width: 100%;
    min-height: 260px;
    border-radius: 18px;
    overflow: visible;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.24), transparent 34%),
      radial-gradient(circle at 85% 18%, rgba(255, 255, 255, 0.12), transparent 22%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.01)),
      linear-gradient(120deg, #151821 0%, #232836 48%, #4a4d62 100%);
  }

  .settings-banner--large::before,
  .settings-banner--large::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .settings-banner--large::before {
    left: -4%;
    bottom: -18%;
    width: 32%;
    height: 72%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0.04));
    clip-path: polygon(0 100%, 0 28%, 54% 0, 100% 44%, 100% 100%);
    opacity: 0.42;
  }

  .settings-banner--large::after {
    right: -8%;
    top: -16%;
    width: 38%;
    height: 88%;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0));
    opacity: 0.8;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar,
  #{{ root_id }}[data-render-mode="section"] .settings-banner--large {
    position: relative;
    left: 50%;
    width: 100vw;
    max-width: 100vw;
    margin: 0 0 0 -50vw;
    border-radius: 0;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--small,
  #{{ root_id }}[data-render-mode="section"] .settings-banner--inline {
    margin: 0 auto;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--small {
    width: min(100%, 320px);
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--inline {
    width: min(100%, 460px);
    min-height: 160px;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--large {
    min-height: 260px;
  }

  @supports (width: 100dvw) {
    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar,
    #{{ root_id }}[data-render-mode="section"] .settings-banner--large {
      width: 100dvw;
      max-width: 100dvw;
      margin-left: calc(-50dvw);
    }
  }

  .settings-banner__scroll {
    display: none;
  }

  .settings-banner__layout {
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 44px 12px 16px;
  }

  .settings-banner--small .settings-banner__layout {
    min-height: 104px;
    padding: 20px 48px 20px 18px;
  }

  .settings-banner--inline .settings-banner__layout {
    min-height: 160px;
    padding: 18px 22px;
  }

  .settings-banner--large .settings-banner__layout {
    min-height: 260px;
    align-items: center;
    justify-content: center;
    padding: 64px clamp(20px, 5vw, 48px) 32px;
  }

  .settings-banner__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    text-align: center;
  }

  .settings-banner--bar .settings-banner__content {
    flex-direction: row;
    gap: 14px;
    flex-wrap: wrap;
  }

  .settings-banner--large .settings-banner__content {
    align-items: center;
    justify-content: center;
    gap: 16px;
    position: relative;
    z-index: 1;
    width: min(100%, 560px);
    min-height: 100%;
    margin: -92px auto 0;
    padding: 0;
    text-align: center;
  }

  .settings-banner__eyebrow {
    margin: 0;
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--settings-banner-muted);
  }

  .settings-banner__title {
    margin: 0;
    font-size: 16px;
    line-height: 1.1;
    font-weight: 700;
    color: var(--settings-banner-text);
  }

  .settings-banner--small .settings-banner__title {
    font-size: 18px;
  }

  .settings-banner--inline .settings-banner__title {
    font-size: 22px;
  }

  .settings-banner--large .settings-banner__title {
    max-width: 12ch;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .settings-banner--bar .settings-banner__title {
    font-size: 14px;
  }

  .settings-banner__link {
    color: var(--settings-banner-text);
    text-decoration: none;
  }

  .settings-banner__text {
    margin: 0;
    max-width: 42ch;
    font-size: 13px;
    line-height: 1.45;
    color: var(--settings-banner-muted);
  }

  .settings-banner--small .settings-banner__text {
    font-size: 12px;
  }

  .settings-banner--inline .settings-banner__text {
    font-size: 14px;
    line-height: 1.5;
    max-width: 32ch;
  }

  .settings-banner--large .settings-banner__text {
    font-size: 14px;
    line-height: 1.6;
    max-width: 42ch;
  }

  .settings-banner__countdown {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 700;
    flex-wrap: wrap;
  }

  .settings-banner__countdown-rail {
    width: 18px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
  }

  .settings-banner__countdown-part {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 22px;
    gap: 2px;
  }

  .settings-banner__countdown-value {
    display: inline-flex;
    width: 22px;
    height: 22px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.98);
    color: #111827;
    font-size: 11px;
    line-height: 1;
  }

  .settings-banner--small .settings-banner__countdown-value {
    font-size: 12px;
  }

  .settings-banner--inline .settings-banner__countdown-value {
    width: 28px;
    height: 28px;
    font-size: 14px;
  }

  .settings-banner--large .settings-banner__countdown-value {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    font-size: 18px;
    font-weight: 800;
    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.2);
  }

  .settings-banner--inline .settings-banner__countdown-label,
  .settings-banner--large .settings-banner__countdown-label {
    display: none;
  }

  .settings-banner--large .settings-banner__eyebrow {
    font-size: 10px;
    line-height: 1.2;
    letter-spacing: 0.28em;
  }

  .settings-banner--large .settings-banner__countdown {
    justify-content: center;
    gap: 10px;
  }

  .settings-banner--large .settings-banner__countdown-part {
    width: 48px;
    gap: 4px;
  }

  .settings-banner--large .settings-banner__countdown-rail {
    width: 28px;
    height: 10px;
    opacity: 0.9;
  }

  .settings-banner--inline .settings-banner__eyebrow {
    font-size: 9px;
    letter-spacing: 0.16em;
  }

  .settings-banner__countdown-label {
    font-size: 8px;
    line-height: 1;
    text-transform: lowercase;
    color: var(--settings-banner-muted);
  }

  .settings-banner__close {
    position: absolute;
    top: 14px;
    right: 14px;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.45);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }

  .settings-banner__close:hover {
    color: rgba(255, 255, 255, 0.78);
  }

  @media (max-width: 768px) {
    .settings-banner__layout {
      min-height: 56px;
      padding: 12px 40px 12px 12px;
    }

    .settings-banner--small,
    .settings-banner--inline {
      max-width: calc(100vw - 16px);
      margin-top: 8px;
    }

    .settings-banner--large .settings-banner__layout {
      min-height: 220px;
      padding: 52px 16px 20px;
    }

    .settings-banner__content {
      gap: 8px;
      flex-direction: column;
    }

    .settings-banner__countdown {
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }

    #{{ root_id }}[data-render-mode="section"] .settings-banner--small,
    #{{ root_id }}[data-render-mode="section"] .settings-banner--inline {
      width: 100%;
    }

    .settings-banner--large {
      min-height: 220px;
    }

    .settings-banner--large .settings-banner__content {
      width: 100%;
      margin-top: -72px;
      padding: 0;
      gap: 12px;
    }

    .settings-banner--large .settings-banner__title {
      max-width: 100%;
      font-size: clamp(22px, 8vw, 32px);
    }

    .settings-banner--large .settings-banner__text {
      max-width: 100%;
      font-size: 13px;
      line-height: 1.5;
    }

    .settings-banner--large .settings-banner__countdown {
      gap: 8px;
    }

    .settings-banner--large .settings-banner__countdown-value,
    .settings-banner--large .settings-banner__countdown-part {
      width: 40px;
    }

    .settings-banner--large .settings-banner__countdown-value {
      height: 40px;
      font-size: 15px;
      border-radius: 12px;
    }

    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar,
    #{{ root_id }}[data-render-mode="section"] .settings-banner--large {
      left: 50%;
      width: 100vw;
      max-width: 100vw;
      margin-left: -50vw;
    }
  }
</style>
