  #{{ root_id }} {
    --settings-banner-panel: linear-gradient(90deg, #18202d 0%, #233047 52%, #1d293b 100%);
    --settings-banner-panel-soft: rgba(255, 255, 255, 0.12);
    --settings-banner-text: #f8fafc;
    --settings-banner-muted: rgba(226, 232, 240, 0.82);
    --settings-banner-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
  }

  #{{ root_id }}[data-render-mode="embed"] {
    position: relative;
    display: block;
    width: 100%;
    max-width: 100%;
    z-index: 20;
    pointer-events: auto;
  }

  #{{ root_id }}[data-render-mode="section"] {
    position: relative;
    width: 100%;
    max-width: 100%;
    overflow: visible;
    pointer-events: auto;
  }

  .settings-banner-stack {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner-stack {
    position: relative;
    left: auto;
    right: auto;
    width: 100%;
    pointer-events: auto;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner-stack {
    position: relative;
    width: 100%;
    overflow: visible;
    pointer-events: auto;
  }

  .settings-banner-stack--top {
    top: 0;
  }

  .settings-banner-stack--bottom {
    bottom: 0;
  }

  .settings-banner {
    width: 100%;
    position: relative;
    pointer-events: auto;
    background: var(--settings-banner-panel);
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: var(--settings-banner-shadow);
    overflow: hidden;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner-stack--top .settings-banner {
    border-top: 0;
    box-shadow: 0 10px 26px rgba(15, 23, 42, 0.14);
  }

  .settings-banner__scroll {
    display: none;
  }

  .settings-banner__layout {
    min-height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 44px 10px 18px;
  }

  .settings-banner__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    text-align: center;
  }

  .settings-banner__eyebrow {
    margin: 0;
    font-size: 10px;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--settings-banner-muted);
  }

  .settings-banner__title {
    margin: 0;
    font-size: 15px;
    line-height: 1.15;
    font-weight: 600;
    color: var(--settings-banner-text);
  }

  .settings-banner__link {
    color: var(--settings-banner-text);
    text-decoration: none;
  }

  .settings-banner__text {
    margin: 0;
    max-width: 42ch;
    font-size: 12px;
    line-height: 1.4;
    color: var(--settings-banner-muted);
  }

  .settings-banner__countdown {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 700;
    flex-wrap: wrap;
  }

  .settings-banner__countdown-rail {
    width: 18px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
  }

  .settings-banner__countdown-part {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 22px;
    gap: 2px;
  }

  .settings-banner__countdown-value {
    display: inline-flex;
    width: 22px;
    height: 22px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.98);
    color: #111827;
    font-size: 11px;
    line-height: 1;
  }

  .settings-banner__countdown-label {
    font-size: 8px;
    line-height: 1;
    text-transform: lowercase;
    color: var(--settings-banner-muted);
  }

  .settings-banner__close {
    position: absolute;
    top: 50%;
    right: 14px;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.48);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    transform: translateY(-50%);
  }

  .settings-banner__close:hover {
    color: rgba(255, 255, 255, 0.78);
  }

  @media (max-width: 768px) {
    .settings-banner__layout {
      min-height: 48px;
      padding: 10px 38px 10px 12px;
    }

    .settings-banner__content {
      gap: 7px;
      flex-direction: column;
    }

    .settings-banner__countdown {
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
