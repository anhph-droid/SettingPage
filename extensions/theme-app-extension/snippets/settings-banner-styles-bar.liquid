  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar {
    position: relative;
    left: auto;
    width: 100%;
    max-width: 100%;
    margin: 0;
    border-radius: 12px;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
  }

  @supports (width: 100dvw) {
    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar {
      width: 100%;
      max-width: 100%;
      margin-left: 0;
    }
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__layout {
    min-height: 58px;
    padding: 10px 18px;
    align-items: center;
    justify-content: center;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__content {
    justify-content: center;
    text-align: center;
    gap: 8px;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__title {
    font-size: 15px;
    line-height: 1.2;
    font-weight: 600;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__text {
    font-size: 12px;
    line-height: 1.35;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar {
    border-radius: 0 0 14px 14px;
    border-top: 0;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__layout {
    min-height: 52px;
    padding: 10px 42px 10px 18px;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__content {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px 16px;
    text-align: center;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__title {
    font-size: 15px;
    letter-spacing: -0.01em;
  }

  #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__text {
    max-width: none;
    font-size: 12px;
    color: rgba(226, 232, 240, 0.88);
  }

  .settings-banner--bar .settings-banner__countdown {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 2px 0;
  }

  .settings-banner--bar .settings-banner__countdown-part {
    width: 42px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .settings-banner--bar .settings-banner__countdown-value {
    width: 42px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--settings-banner-text, #111827);
    font-size: 14px;
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.03em;
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
  }

  .settings-banner--bar .settings-banner__countdown-label {
    display: block;
    font-size: 8px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.68;
  }

  .settings-banner--bar .settings-banner__countdown-rail {
    width: 12px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.18;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown {
    gap: 9px;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown-part {
    width: 46px;
    gap: 5px;
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown-value {
    width: 46px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.84);
    font-size: 14px;
    box-shadow: inset 0 0 0 1px rgba(17, 24, 39, 0.06);
  }

  #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown-label {
    font-size: 8px;
    letter-spacing: 0.14em;
  }

  .settings-banner--bar .settings-banner__content {
    flex-direction: row;
    gap: 12px;
    flex-wrap: wrap;
  }

  .settings-banner--bar .settings-banner__title {
    font-size: 14px;
  }

  @media (max-width: 768px) {
    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__layout {
      min-height: 48px;
      padding: 8px 12px;
    }

    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__title {
      font-size: 14px;
    }

    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__text {
      font-size: 11px;
    }

    #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__layout {
      min-height: 50px;
      padding: 8px 34px 8px 12px;
    }

    #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__content {
      gap: 8px 10px;
    }

    #{{ root_id }}[data-render-mode="embed"] .settings-banner--bar .settings-banner__title {
      font-size: 13px;
    }

    .settings-banner--bar .settings-banner__countdown {
      gap: 6px;
    }

    .settings-banner--bar .settings-banner__countdown-part,
    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown-part {
      width: 36px;
      gap: 3px;
    }

    .settings-banner--bar .settings-banner__countdown-value,
    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown-value {
      width: 36px;
      height: 28px;
      font-size: 12px;
      border-radius: 7px;
    }

    .settings-banner--bar .settings-banner__countdown-label,
    #{{ root_id }}[data-render-mode="section"] .settings-banner--bar .settings-banner__countdown-label {
      font-size: 7px;
    }

    .settings-banner--bar .settings-banner__countdown-rail {
      width: 8px;
    }
  }
